# Cortex hosted SaaS environment.
# Copy into Railway, Supabase-backed hosting, or your secret manager.

# Required: one Supabase Postgres database/project for the hosted control plane.
# Prefer the direct connection when your host supports IPv6. Use Supavisor
# session mode for long-running web and worker containers when direct IPv6 is
# unavailable.
CORTEX_DATABASE_URL=postgresql://postgres.PROJECT_REF:PASSWORD@POOLER_HOST_FROM_SUPABASE:5432/postgres

# If you must use Supavisor transaction mode on port 6543, disable prepared
# statements with either ?prepare=false in CORTEX_DATABASE_URL or CORTEX_PREPARE=false.
# CORTEX_DATABASE_URL=postgresql://postgres.PROJECT_REF:PASSWORD@POOLER_HOST_FROM_SUPABASE:6543/postgres?prepare=false
# CORTEX_PREPARE=false

# Set this when the host cannot reach Supabase's direct db.<ref>.supabase.co
# endpoint. Railway commonly needs pooler-only DDL unless direct IPv6 has
# been verified.
CORTEX_DISABLE_DIRECT_POOL=1

# Public web/API origin. Railway deployments derive this from
# RAILWAY_PUBLIC_DOMAIN when it is available, but custom domains should set it
# explicitly so OAuth issuer metadata and onboarding URLs stay stable.
CORTEX_PUBLIC_URL=https://brain.example.com
CORTEX_HTTP_CORS_ORIGIN=https://brain.example.com
CORTEX_HTTP_TRUST_PROXY=1

# Admin bootstrap. Generate with: openssl rand -hex 32
CORTEX_ADMIN_BOOTSTRAP_TOKEN=
CORTEX_SUPPRESS_BOOTSTRAP_TOKEN=1

# Provider keys.
ZEROENTROPY_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Composio ingestion connectors.
COMPOSIO_API_KEY=
CORTEX_COMPOSIO_WEBHOOK_SECRET=

# Invite and onboarding email delivery. The web/admin route can inspect the
# outbox; worker services call /jobs/invite-deliveries/drain with this secret.
CORTEX_EMAIL_PROVIDER=resend
RESEND_API_KEY=
CORTEX_EMAIL_FROM=Cortex <onboarding@example.com>
CORTEX_EMAIL_DELIVERY_SECRET=

# Billing/subscription reconciliation. Configure your billing provider to send
# subscription lifecycle events to /webhooks/billing with this secret as
# Bearer, x-cortex-billing-secret, or x-cortex-webhook-secret.
CORTEX_BILLING_WEBHOOK_SECRET=

# Runtime tuning.
CORTEX_HOME=/data/cortex
CORTEX_AUDIT_DIR=/data/cortex/audit
PORT=3131
CORTEX_BIND=0.0.0.0
CORTEX_POOL_SIZE=2
CORTEX_WORKER_CONCURRENCY=2

# Railway worker service only: set CORTEX_PROCESS=worker on the worker service.
# Leave unset or set to web for the public web service.
# CORTEX_PROCESS=worker

# Set to 1 only for standalone worker services that do not have a release
# migration step or a web process applying schema readiness first.
CORTEX_WORKER_RUN_SCHEMA_MIGRATIONS=0

# Enable only when you intentionally want hosted shell-job execution.
# CORTEX_ALLOW_SHELL_JOBS=1

# Default web startup applies cheap schema readiness only. Set this to 1 on
# platforms without a release/migrate phase.
CORTEX_RUN_FULL_MIGRATIONS_ON_START=0

# Keep DCR off unless you intentionally support dynamic client registration
# for trusted integration flows.
CORTEX_ENABLE_DCR=0
