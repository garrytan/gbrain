#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
CLI_CURATED_LOG_DIR="${CURATED_LOG_DIR:-}"
CLI_CURATED_STAGE="${CURATED_STAGE:-}"
eval "$(/usr/bin/python3 "$SCRIPT_DIR/config_loader.py" shell)"
LOG_DIR="${CLI_CURATED_LOG_DIR:-${CURATED_LOG_DIR:-$HOME/workspace/tools/gbrain-curated-logs}}"
STAGE_DIR="${CLI_CURATED_STAGE:-${CURATED_STAGE:-$HOME/workspace/tools/gbrain-curated-stage}}"

usage() {
  cat <<'EOF'
gbrain-curated — TT curated gbrain helper

Usage:
  gbrain-curated help
  gbrain-curated status
  gbrain-curated dashboard
  gbrain-curated cleanup [keep]
  gbrain-curated smoke
  gbrain-curated regression
  gbrain-curated baseline
  gbrain-curated weekly
  gbrain-curated refresh [manifest.json]
  gbrain-curated refresh-replay <manifest.json>
  gbrain-curated nightly
  gbrain-curated logs [smoke|regression|weekly|refresh|nightly]
EOF
}

latest_file() {
  local pattern="$1"
  python - <<'PY' "$LOG_DIR" "$pattern"
from pathlib import Path
import sys
log_dir = Path(sys.argv[1])
pattern = sys.argv[2]
files = sorted(log_dir.glob(pattern), key=lambda p: p.stat().st_mtime, reverse=True)
print(files[0] if files else "")
PY
}

show_status() {
  python - <<'PY' "$LOG_DIR"
import json, sys
from pathlib import Path
log_dir = Path(sys.argv[1])

def load(name):
    path = log_dir / name
    if not path.exists():
        return None
    return json.loads(path.read_text())

smoke = load('refresh-smoke-last.json')
reg = load('query-regression-last.json')
weekly = load('weekly-baseline-review.json')

print('gbrain curated status')
if smoke:
    print(f"- smoke: {'ok' if smoke.get('ok') else 'fail'} ({smoke.get('passed')}/{smoke.get('total')})")
else:
    print('- smoke: no snapshot')
if reg:
    print(f"- regression: {'ok' if reg.get('ok') else 'fail'} ({reg.get('passed')}/{reg.get('total')}) drift={reg.get('severe_drift_count')}")
else:
    print('- regression: no snapshot')
if weekly:
    r = weekly.get('regression', {})
    s = weekly.get('smoke', {})
    print(f"- weekly: regression={r.get('passed')}/{r.get('total')} smoke={s.get('passed')}/{s.get('total')}")
else:
    print('- weekly: no snapshot')
PY
}

show_log() {
  local kind="${1:-nightly}"
  case "$kind" in
    smoke) latest_file 'refresh-smoke-*.log' ;;
    regression) printf '%s\n' "$LOG_DIR/query-regression-last.json" ;;
    weekly) printf '%s\n' "$LOG_DIR/weekly-baseline-review.json" ;;
    refresh) latest_file 'cron-refresh-import-extract-*.log' ;;
    nightly) latest_file 'cron-embed-health-regression-*.log' ;;
    *) echo "unknown log kind: $kind" >&2; exit 1 ;;
  esac
}

run_manifest_refresh() {
  local manifest_path="$1"
  local replay_flag="${2:-0}"
  /usr/bin/python3 - <<'PY' "$SCRIPT_DIR" "$STAGE_DIR" "$LOG_DIR" "$manifest_path" "$replay_flag"
import json, sys
from pathlib import Path
script_dir = Path(sys.argv[1])
stage = Path(sys.argv[2])
log_dir = Path(sys.argv[3])
manifest = Path(sys.argv[4])
replay = sys.argv[5] == '1'
sys.path.insert(0, str(script_dir))
from refresh_manifest_consumer import execute_refresh_plan
payload = execute_refresh_plan(
    manifest_path=manifest,
    curated_stage=stage,
    curated_log_dir=log_dir,
    script_dir=script_dir,
    replay=replay,
)
print(json.dumps(payload, ensure_ascii=False))
raise SystemExit(0 if payload.get('ok') else 1)
PY
}

render_dashboard() {
  /usr/bin/python3 - <<'PY' "$SCRIPT_DIR" "$LOG_DIR"
import json, sys
from pathlib import Path
script_dir = Path(sys.argv[1])
log_dir = Path(sys.argv[2])
sys.path.insert(0, str(script_dir))
from refresh_manifest_consumer import build_control_plane_artifacts
payload = build_control_plane_artifacts(log_dir=log_dir, output_dir=log_dir / 'control-plane')
print(json.dumps(payload, ensure_ascii=False))
PY
}

run_cleanup() {
  local keep="${1:-20}"
  /usr/bin/python3 - <<'PY' "$SCRIPT_DIR" "$LOG_DIR" "$keep"
import json, sys
from pathlib import Path
script_dir = Path(sys.argv[1])
log_dir = Path(sys.argv[2])
keep = int(sys.argv[3])
sys.path.insert(0, str(script_dir))
from refresh_manifest_consumer import gc_old_manifests
manifest_root = log_dir.parent / '.meta-fallback-manifests'
print(json.dumps(gc_old_manifests(manifest_root, keep=keep), ensure_ascii=False))
PY
}

cmd="${1:-help}"
case "$cmd" in
  help|-h|--help)
    usage
    ;;
  status)
    show_status
    ;;
  dashboard)
    render_dashboard
    ;;
  cleanup)
    run_cleanup "${2:-20}"
    ;;
  smoke)
    bash -ic "$SCRIPT_DIR/refresh-smoke-check.sh"
    ;;
  regression)
    bash -ic "$SCRIPT_DIR/query-regression.py"
    ;;
  baseline)
    bash -ic "$SCRIPT_DIR/query-regression.py --write-baseline"
    ;;
  weekly)
    bash -ic "$SCRIPT_DIR/weekly-baseline-review.py"
    ;;
  refresh)
    if [[ -n "${2:-}" ]]; then
      run_manifest_refresh "$2" 0
    else
      bash -ic "$SCRIPT_DIR/cron-refresh-import-extract.sh"
    fi
    ;;
  refresh-replay)
    if [[ -z "${2:-}" ]]; then
      echo 'refresh-replay requires a manifest path' >&2
      exit 1
    fi
    run_manifest_refresh "$2" 1
    ;;
  nightly)
    bash -ic "$SCRIPT_DIR/cron-embed-health-regression.sh"
    ;;
  logs)
    show_log "${2:-nightly}"
    ;;
  *)
    echo "unknown command: $cmd" >&2
    usage >&2
    exit 1
    ;;
esac
