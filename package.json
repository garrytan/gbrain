{
  "name": "gbrain",
  "version": "0.41.14.0",
  "description": "Postgres-native personal knowledge brain with hybrid RAG search",
  "type": "module",
  "main": "src/core/index.ts",
  "bin": {
    "gbrain": "src/cli.ts"
  },
  "exports": {
    ".": "./src/core/index.ts",
    "./engine": "./src/core/engine.ts",
    "./types": "./src/core/types.ts",
    "./operations": "./src/core/operations.ts",
    "./minions": "./src/core/minions/index.ts",
    "./engine-factory": "./src/core/engine-factory.ts",
    "./pglite-engine": "./src/core/pglite-engine.ts",
    "./link-extraction": "./src/core/link-extraction.ts",
    "./import-file": "./src/core/import-file.ts",
    "./transcription": "./src/core/transcription.ts",
    "./embedding": "./src/core/embedding.ts",
    "./config": "./src/core/config.ts",
    "./markdown": "./src/core/markdown.ts",
    "./backoff": "./src/core/backoff.ts",
    "./search/hybrid": "./src/core/search/hybrid.ts",
    "./search/expansion": "./src/core/search/expansion.ts",
    "./ai/gateway": "./src/core/ai/gateway.ts",
    "./extract": "./src/commands/extract.ts",
    "./ingestion": "./src/core/ingestion/index.ts",
    "./ingestion/test-harness": "./src/core/ingestion/test-harness.ts"
  },
  "scripts": {
    "dev": "bun run src/cli.ts",
    "build": "bun build --compile --outfile bin/gbrain src/cli.ts",
    "build:all": "bun build --compile --target=bun-darwin-arm64 --outfile bin/gbrain-darwin-arm64 src/cli.ts && bun build --compile --target=bun-linux-x64 --outfile bin/gbrain-linux-x64 src/cli.ts",
    "build:admin": "cd admin && bun run build && cd .. && bun run scripts/build-admin-embedded.ts",
    "build:admin-embedded": "bun run scripts/build-admin-embedded.ts",
    "build:schema": "bun run scripts/run-bash.ts scripts/build-schema.sh",
    "build:llms": "bun run scripts/build-llms.ts",
    "build:pglite-snapshot": "bun run scripts/build-pglite-snapshot.ts",
    "test": "bun run scripts/run-bash.ts scripts/run-unit-parallel.sh",
    "test:full": "bun run scripts/test-full.ts",
    "verify": "bun run scripts/run-bash.ts scripts/run-verify-parallel.sh",
    "check:source-config-leak": "bun run scripts/run-bash.ts scripts/check-source-config-leak.sh",
    "check:no-pii-agent-voice": "bun run scripts/run-bash.ts scripts/check-no-pii-in-agent-voice.sh",
    "check:synthetic-corpus-privacy": "bun run scripts/run-bash.ts scripts/check-synthetic-corpus-privacy.sh",
    "check:system-of-record": "bun run scripts/run-bash.ts scripts/check-system-of-record.sh",
    "check:admin-scope-drift": "bun run scripts/run-bash.ts scripts/check-admin-scope-drift.sh",
    "check:cli-exec": "bun run scripts/run-bash.ts scripts/check-cli-executable.sh",
    "check:all": "bun run check:privacy && bun run check:proposal-pii && bun run check:test-names && bun run check:jsonb && bun run check:source-id-projection && bun run check:source-config-leak && bun run check:progress && bun run check:no-legacy-getconnection && bun run check:test-isolation && bun run check:newlines && bun run check:wasm && bun run check:exports-count && bun run check:admin-build && bun run check:admin-scope-drift && bun run check:cli-exec && bun run check:skill-brain-first && bun run check:operations-filter-bypass && bun run check:gateway-routed",
    "check:gateway-routed": "bun run scripts/run-bash.ts scripts/check-gateway-routed-no-direct-anthropic.sh",
    "check:resolver": "bun src/cli.ts check-resolvable --strict --skills-dir skills/",
    "check:skill-brain-first": "bun run scripts/run-bash.ts scripts/check-skill-brain-first.sh",
    "check:wasm": "bun run scripts/run-bash.ts scripts/check-wasm-embedded.sh",
    "check:newlines": "bun run scripts/run-bash.ts scripts/check-trailing-newline.sh",
    "test:e2e": "bun run scripts/run-bash.ts scripts/run-e2e.sh",
    "test:slow": "bun run scripts/run-bash.ts scripts/run-slow-tests.sh",
    "test:heavy": "bun run scripts/run-bash.ts scripts/run-heavy.sh",
    "test:profile": "bun run scripts/run-bash.ts scripts/profile-tests.sh",
    "test:serial": "bun run scripts/run-bash.ts scripts/run-serial-tests.sh",
    "ci:local": "bun run scripts/run-bash.ts scripts/ci-local.sh",
    "ci:local:diff": "bun run scripts/run-bash.ts scripts/ci-local.sh --diff",
    "ci:select-e2e": "bun run scripts/select-e2e.ts",
    "typecheck": "tsc --noEmit",
    "check:jsonb": "bun run scripts/run-bash.ts scripts/check-jsonb-pattern.sh",
    "check:source-id-projection": "bun run scripts/run-bash.ts scripts/check-source-id-projection.sh",
    "check:privacy": "bun run scripts/run-bash.ts scripts/check-privacy.sh",
    "check:proposal-pii": "bun run scripts/run-bash.ts scripts/check-proposal-pii.sh",
    "check:eval-glossary": "bun run scripts/run-bash.ts scripts/check-eval-glossary-fresh.sh",
    "check:test-names": "bun run scripts/run-bash.ts scripts/check-test-real-names.sh",
    "check:progress": "bun run scripts/run-bash.ts scripts/check-progress-to-stdout.sh",
    "check:no-legacy-getconnection": "bun run scripts/run-bash.ts scripts/check-no-legacy-getconnection.sh",
    "check:exports-count": "bun run scripts/run-bash.ts scripts/check-exports-count.sh",
    "check:admin-build": "bun run scripts/run-bash.ts scripts/check-admin-build.sh",
    "check:admin-embedded": "bun run scripts/run-bash.ts scripts/check-admin-embedded.sh",
    "check:test-isolation": "bun run scripts/run-bash.ts scripts/check-test-isolation.sh",
    "check:fuzz-purity": "bun run scripts/run-bash.ts scripts/check-fuzz-purity.sh",
    "check:operations-filter-bypass": "bun run scripts/run-bash.ts scripts/check-operations-filter-bypass.sh",
    "postinstall": "bun run scripts/postinstall.ts",
    "prepublish:clawhub": "bun run build:all",
    "publish:clawhub": "clawhub package publish . --family bundle-plugin"
  },
  "openclaw": {
    "compat": {
      "pluginApi": ">=2026.4.0"
    },
    "extensions": [
      "./src/openclaw-context-engine.ts"
    ]
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.71",
    "@ai-sdk/google": "^3.0.64",
    "@ai-sdk/openai": "^3.0.53",
    "@ai-sdk/openai-compatible": "^2.0.41",
    "@anthropic-ai/sdk": "^0.30.0",
    "@aws-sdk/client-s3": "^3.1028.0",
    "@dqbd/tiktoken": "^1.0.22",
    "@electric-sql/pglite": "0.4.3",
    "@jsquash/avif": "^2.1.1",
    "@jsquash/png": "^3.1.1",
    "@modelcontextprotocol/sdk": "1.29.0",
    "ai": "^6.0.168",
    "chokidar": "^4.0.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "eventsource-parser": "^3.0.8",
    "exifr": "^7.1.3",
    "express": "^5.1.0",
    "express-rate-limit": "^7.5.0",
    "gray-matter": "^4.0.3",
    "heic-decode": "^2.1.0",
    "js-yaml": "^3.14.2",
    "marked": "^18.0.0",
    "openai": "^4.0.0",
    "pgvector": "^0.2.0",
    "postgres": "^3.4.0",
    "tree-sitter-wasms": "0.1.13",
    "web-tree-sitter": "0.22.6",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/cookie-parser": "^1.4.7",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/js-yaml": "^3.12.10",
    "bun-types": "^1.3.13",
    "fast-check": "^4.8.0",
    "typescript": "^5.6.0"
  },
  "trustedDependencies": [
    "@electric-sql/pglite"
  ],
  "engines": {
    "bun": ">=1.3.10"
  },
  "license": "MIT"
}
