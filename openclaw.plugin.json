{
  "name": "gbrain",
  "version": "0.4.1",
  "description": "Personal knowledge brain with Postgres + pgvector hybrid search",
  "family": "bundle-plugin",
  "configSchema": {
    "database_url": {
      "type": "string",
      "required": true,
      "description": "PostgreSQL connection URL (Supabase recommended)",
      "uiHints": { "sensitive": true }
    },
    "embedding_provider": {
      "type": "string",
      "required": false,
      "description": "Embedding provider to use: openai or venice"
    },
    "openai_api_key": {
      "type": "string",
      "required": false,
      "description": "OpenAI-compatible API key for embeddings (uses OPENAI_API_KEY env var if not set)",
      "uiHints": { "sensitive": true }
    },
    "openai_base_url": {
      "type": "string",
      "required": false,
      "description": "Optional OpenAI-compatible base URL (set to Venice to use OPENAI-compatible routing)"
    },
    "venice_api_key": {
      "type": "string",
      "required": false,
      "description": "Venice API key for embeddings (uses VENICE_API_KEY env var if not set)",
      "uiHints": { "sensitive": true }
    },
    "venice_base_url": {
      "type": "string",
      "required": false,
      "description": "Optional Venice base URL override",
      "uiHints": { "sensitive": true }
    }
  },
  "mcpServers": {
    "gbrain": {
      "command": "./bin/gbrain",
      "args": ["serve"]
    }
  },
  "skills": [
    "skills/ingest",
    "skills/query",
    "skills/maintain",
    "skills/enrich",
    "skills/briefing",
    "skills/migrate",
    "skills/setup"
  ],
  "openclaw": {
    "compat": {
      "pluginApi": ">=2026.4.0"
    }
  }
}
