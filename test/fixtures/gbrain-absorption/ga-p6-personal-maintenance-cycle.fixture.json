    {
      "case_id": "redaction_fail_closed",
      "requested_mode": "apply",
      "target_surface": "redaction_plan",
      "unsupported_target_behavior": "fail_closed",
      "expected_decision": "failed",
      "expected_ledger_outcome": "redacted_or_failed",
