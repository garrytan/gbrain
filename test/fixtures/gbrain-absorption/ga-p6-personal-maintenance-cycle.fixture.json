      "expected_decision": "staged_for_review",
      "expected_mutation_surface": "governance_state",
      "candidate_grants_truth": false,
      "requires_source_refs": true
    },
    {
      "case_id": "apply_requires_realm_session",
      "requested_mode": "apply",
      "missing_requirement": "active_realm_session",
      "expected_decision": "denied",
      "expected_ledger_outcome": "denied",
      "expected_mutation": false
    },
    {
      "case_id": "apply_requires_target_snapshot",
      "requested_mode": "apply",
      "missing_requirement": "target_snapshot",
      "expected_decision": "conflict",
      "expected_ledger_outcome": "conflict",
      "expected_mutation": false
    },
    {
      "case_id": "dry_run_apply_validation_parity",
      "requested_mode": "dry_run",
